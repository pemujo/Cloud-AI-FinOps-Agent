# -----------------------------------------------------------------------------
# GCP Billing Concierge - Environment Variables Blueprint
# Copy this file to '.env' and fill in your values.
# IMPORTANT: Never commit your actual '.env' file to version control.
# -----------------------------------------------------------------------------

# --- Vertex AI & Agent Configuration ---
# The model, project and region where your Agent Engine will be deployed.
GOOGLE_CLOUD_PROJECT="your-project-id"
GOOGLE_CLOUD_LOCATION="us-central1"
GEMINI_MODEL="gemini-2.5-flash"

# --- Billing Data Source (BigQuery) ---
# Details for your existing BQ Billing Export.
# If using sample data, these will be populated by 'scripts/setup_billing_data.py'.
BILLING_EXPORT_PROJECT_ID="your-billing-export-project"
BILLING_EXPORT_DATASET="billing_export_dataset"
BILLING_EXPORT_TABLE="gcp_billing_export_v1_XXXXXX"

# --- Internal Agent Settings ---
# These variables ensure the ADK and Vertex SDKs communicate correctly.
# Do not change these unless you are an advanced user.
GOOGLE_CLOUD_AGENT_ENGINE_ENABLE_TELEMETRY=true
GOOGLE_GENAI_USE_VERTEXAI=1

